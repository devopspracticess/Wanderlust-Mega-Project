@Library('CommonLib') _
pipeline {
    agent any
    
    environment{
        SONAR_HOME = tool "Sonar"
    }
    
    parameters {
        string(name: 'Docker_F_Tag', defaultValue: '', description: 'docker image for latest push')
        string(name: 'Docker_B_Tag', defaultValue: '', description: 'docker image for latest push')
    }
    
    stages {
        stage("Validate Parameters") {
            steps {
                script {
                    if (params.Docker_F_Tag == '' || params.Docker_B_Tag == '') {
                        error("Docker_F_Tag and Docker_B_Tag must be provided.")
                    }
                }
            }
        }
        stage("Workspace cleanup"){
            steps{
                script{
                    cleanWs()
                }
            }
        }
        
        stage('Git: Code Checkout') {
            steps {
                script{
                    code_checkout("https://github.com/mrvanny/the-traveler.git","main")
                }
            }
        }
        
        stage("Trivy: Filesystem scan"){
            steps{
                script{
                    trivy_scan()
                }
            }
        }

        stage("OWASP: Dependency check"){
            steps{
                script{
                    owasp_dependency()
                }
            }
        }
        
        stage("SonarQube: Code Analysis"){
            steps{
                script{
                    sonarqube_analysis("Sonar","thetraveler","thetraveler")
                }
            }
        }
        
        stage("SonarQube: Code Quality Gates"){
            steps{
                script{
                    sonarqube_code_quality()
                }
            }
        }
        
        stage('Exporting environment variables') {
            parallel{
                stage("Backend env setup"){
                    steps {
                        script{
                            dir("ResourceUpdate"){
                                sh "bash updatebackendenv.sh"
                            }
                        }
                    }
                }
                
                stage("Frontend env setup"){
                    steps {
                        script{
                            dir("ResourceUpdate"){
                                sh "bash updatefrontendenv.sh"
                            }
                        }
                    }
                }
            }
        }
        
        stage("Docker: Build Images"){
            steps{
                script{
                        dir('backend'){
                            docker_build("thetraveler-backend-beta","${params.Docker_B_Tag}","theroot77")
                        }
                    
                        dir('frontend'){
                            docker_build("thetraveler-frontend-beta","${params.Docker_F_Tag}","theroot77")
                        }
                }
            }
        }
        
        stage("Docker: Push to DockerHub"){
            steps{
                script{
                    docker_push("thetraveler-backend-beta","${params.Docker_B_Tag}") 
                    docker_push("thetraveler-frontend-beta","${params.Docker_F_Tag}")
                }
            }
        }
    }
    post{
        success{
            archiveArtifacts artifacts: 'dependency-check-report/*.xml', fingerprint: true
            build job: "Traveler-CD", parameters: [
                string(name: 'Docker_F_Tag', value: "${params.Docker_F_Tag}"),
                string(name: 'Docker_B_Tag', value: "${params.Docker_B_Tag}")
            ]
        }
    }
}

